# ===== Database =====
DB_USERNAME=root
DB_PASSWORD=your-db-password

# ===== JWT =====
# Generate with:  openssl rand -base64 64
JWT_SECRET=your-super-long-random-secret-here

# ===== Admin bootstrap =====
# These values are read by educore-auth-service on first startup ONLY
# (when no admin row exists yet). After the admin is created they are
# ignored, so it is safe to leave them blank in the running container.
#
# ADMIN_INIT_PASSWORD is REQUIRED on first boot. There is no default —
# the auth service will refuse to start until you provide a strong value.
# The bootstrapped admin is forced to rotate this password on first login
# via POST /api/v1/auth/change-password.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@educore.local
ADMIN_INIT_PASSWORD=change-me-to-a-strong-password
